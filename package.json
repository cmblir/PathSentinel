{
  "name": "path-sentinel",
  "version": "1.1.0",
  "description": "MCP server that scans project paths for hardcoded secrets, sensitive config files, and privacy-restricted paths before they reach an LLM.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "path-sentinel": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_KR.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "node --test --import tsx \"src/__tests__/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "secrets",
    "scanner",
    "claude",
    "llm",
    "privacy"
  ],
  "author": "cmblir",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmblir/PathSentinel.git"
  },
  "bugs": {
    "url": "https://github.com/cmblir/PathSentinel/issues"
  },
  "homepage": "https://github.com/cmblir/PathSentinel#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glob": "^13.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
